<c74object name="dot.autoscale" module="dot" kind="patcher">
	<digest>
        Automatically rescale a stream using min and max.
	</digest>
	<description>
        Automatically rescale a stream using min and max.
	</description>

	<!--METADATA-->
	<metadatalist>
		<metadata name="author">Joseph Malloch</metadata>
		<metadata name="copyright">© 2006 - 2026</metadata>
		<metadata name="version">1.3</metadata>
        <metadata name="tag">Digital Orchestral Toolbox</metadata>
	</metadatalist>

	<!--INLETS-->
	<inletlist>
		<inlet id="0" type="int/float">
			<digest>
                stream of values to rescale
			</digest>
			<description>
			</description>
		</inlet>
        <inlet id="1" type="int/float">
            <digest>
                input-low
            </digest>
            <description>
            </description>
        </inlet>
        <inlet id="2" type="int/float">
            <digest>
                input-high
            </digest>
            <description>
            </description>
        </inlet>
        <inlet id="3" type="int/float">
            <digest>
                output-low
            </digest>
            <description>
            </description>
        </inlet>
        <inlet id="4" type="int/float">
            <digest>
                output-high
            </digest>
            <description>
            </description>
        </inlet>
	</inletlist>

	<!--OUTLETS-->
	<outletlist>
		<outlet id="0" type="float">
			<digest>
                rescaled value
			</digest>
			<description>
			</description>
		</outlet>
        <outlet id="1" type="list">
            <digest>
                input minimum used for rescaling
            </digest>
            <description>
            </description>
        </outlet>
        <outlet id="2" type="list">
            <digest>
                input maximum used for rescaling
            </digest>
            <description>
            </description>
        </outlet>
	</outletlist>

    <!--ATTRIBUTES-->
    <attributelist>
        <attribute name="input-low" get="0" set="1" type="float" size="1">
            <digest>
                input-low
            </digest>
            <description>
                Input minimum to use for rescaling
            </description>
        </attribute>

        <attribute name="input-high" get="0" set="1" type="float" size="1">
            <digest>
                input-high
            </digest>
            <description>
                Input maximum to use for rescaling
            </description>
        </attribute>

        <attribute name="output-low" get="0" set="1" type="float" size="1">
            <digest>
                output-low
            </digest>
            <description>
                Output minimum to use for rescaling
            </description>
        </attribute>

        <attribute name="output-high" get="0" set="1" type="float" size="1">
            <digest>
                output-high
            </digest>
            <description>
                Output maximum to use for rescaling
            </description>
        </attribute>
    </attributelist>

    <!--MESSAGES-->
    <methodlist>
        <method name="input-low">
            <arglist>
                <arg name="value" type="float" optional="0" />
            </arglist>
            <digest>
                input-low
            </digest>
            <description>
                Input minimum to use for rescaling
            </description>
        </method>
        <method name="input-high">
            <arglist>
                <arg name="value" type="float" optional="0" />
            </arglist>
            <digest>
                input-high
            </digest>
            <description>
                Input maximum to use for rescaling
            </description>
        </method>
        <method name="output-low">
            <arglist>
                <arg name="value" type="float" optional="0" />
            </arglist>
            <digest>
                output-low
            </digest>
            <description>
                Output minimum to use for rescaling
            </description>
        </method>
        <method name="output-high">
            <arglist>
            </arglist>
            <digest>
                output-high
            </digest>
            <description>
                Output maximum to use for rescaling
            </description>
        </method>
    </methodlist>

	<!--SEEALSO-->
	<seealsolist>
        <seealso name="dot.autoscale.exponential" />
        <seealso name="dot.autoscale.sliding" />
        <seealso name="dot.autoscale.timed" />
	</seealsolist>

